// ======================== Пины =========================
#define SIM800_TX 2
#define SIM800_RX 3
#define SIM800_RST 5
#define RELAY_OPEN 8
#define RELAY_CLOSE 9
#define FLASH_CS 10

// ======================== Отладка ======================
// С сайта через get_hash: serial_debug → UART; gateway_log_level → отправка action=log
#ifndef ENABLE_DEBUG_LOGS
#define ENABLE_DEBUG_LOGS 1
#endif
bool g_serialDebug = (ENABLE_DEBUG_LOGS != 0);
uint8_t g_gatewayLogLevel = 2;
#define SIM800_VERBOSE // Раскомментируйте для подробных строк SIM800

#if ENABLE_DEBUG_LOGS
  #define DEBUG_PRINT(x)    do { if (g_serialDebug) Serial.print(x); } while (0)
  #define DEBUG_PRINTLN(x)  do { if (g_serialDebug) Serial.println(x); } while (0)
#else
  #define DEBUG_PRINT(x)    do { } while (0)
  #define DEBUG_PRINTLN(x)  do { } while (0)
#endif

#if defined(SIM800_VERBOSE)
  #define SIM800_LOG(line) do { if (g_serialDebug) { Serial.print(F("SIM800: ")); safePrintln(line); } } while (0)
#else
  #define SIM800_LOG(line) do { } while (0)
#endif

// Безопасная печать только печатных символов (чтобы не засорять лог)
void safePrint(const char* s) {
  while (*s) {
    if (isPrintable((uint8_t)*s)) Serial.print(*s);
    else Serial.print('.');
    s++;
  }
}

void safePrintln(const char* s) {
  safePrint(s);
  Serial.println();
}

static bool equalsIgnoreCase(const char* a, const char* b) {
  if (!a || !b) return false;
  while (*a && *b) {
    if (tolower((unsigned char)*a) != tolower((unsigned char)*b)) return false;
    a++;
    b++;
  }
  return *a == '\0' && *b == '\0';
}

static void trimInPlace(char* s) {
  if (!s) return;
  int n = (int)strlen(s);
  while (n > 0 && (s[n - 1] == '\r' || s[n - 1] == '\n' || s[n - 1] == ' ' || s[n - 1] == '\t')) {
    s[--n] = '\0';
  }
  char* p = s;
  while (*p == ' ' || *p == '\r' || *p == '\n' || *p == '\t') p++;
  if (p != s) memmove(s, p, strlen(p) + 1);
}

bool isHexToken32(const char* s) {
  if (!s) return false;
  for (uint8_t i = 0; i < 32; i++) {
    char c = s[i];
    bool ok = ((c >= '0' && c <= '9') ||
               (c >= 'a' && c <= 'f') ||
               (c >= 'A' && c <= 'F'));
    if (!ok) return false;
  }
  return s[32] == '\0';
}

// ======================== Константы ====================
#define RECORD_SIZE 17
#define MAX_PHONE_LEN 15
#define PHONE_RECORDS_CAP 10000
#define PHONE_TABLE_BYTES ((uint32_t)PHONE_RECORDS_CAP * RECORD_SIZE)
// Заголовок в секторе 0 (0x0000..0x0FFF). Записи — со 2-го сектора, иначе
// writeHeader() делает Sector Erase по 0x0000 и стирает только что записанные номера.
#define FLASH_SECTOR_SIZE 4096UL
#define FLASH_HEADER_ADDR 0UL
#define FLASH_DATA_BASE FLASH_SECTOR_SIZE /* 0x1000 */
// Вторая копия таблицы (выровнена по сектору): пересборка при смене группы без NOR-patch и без полного HTTP.
#define PHONE_TABLE_SECTOR_ALIGN (((PHONE_TABLE_BYTES + FLASH_SECTOR_SIZE - 1) / FLASH_SECTOR_SIZE) * FLASH_SECTOR_SIZE)
#define FLASH_SHADOW_BASE (FLASH_DATA_BASE + PHONE_TABLE_SECTOR_ALIGN)
#define FLASH_NUMBERS_END (FLASH_SHADOW_BASE + PHONE_TABLE_SECTOR_ALIGN)
#define SYNC_INTERVAL 300000UL
/* Минимум между HTTP get_data при пошаговой загрузке — loop() успевает обслужить URC/UART */
#define NUMBER_DOWNLOAD_INTERVAL_MS 300UL
/* Меньше записей за запрос — короче JSON, меньше httpBuffer (критично для ATmega328) */
#define PAGE_LIMIT 2
/* get_hash с api_token/next/relay — ~260+ байт JSON; уменьшать нельзя без правки API */
#define HTTP_BUFFER_SIZE 264
/* Порог «мало RAM»: после ужатия буферов держим ниже, иначе вечный skip HTTP */
#define LOW_RAM_GUARD 72
/* Лог JSON + очередь SMS с сервера (не одновременно) + USSD command_ack */
#define LOG_JSON_BUF_SIZE 132


// Сервер и APN (замените на свои)
#define SERVER_URL "ugline.ru/testgate/api"
#define API_TOKEN_FALLBACK "14ae481d827aa7dfc2b59265a9f1c422"
#define APN "internet"          // Измените на APN вашего оператора
#define APN_USER ""
#define APN_PASS ""

// ======================== Структуры ====================
struct FlashHeader {
  uint16_t magic;
  uint8_t version;
  uint16_t recordCount;
  char hash[33];
  char apiToken[33]; // Синхронизируется с сайта и хранится во Flash
  uint32_t lastServerSyncTs; // server_time из get_hash — для дельта-sync (только изменённые строки)
};

// ======================== Глобальные переменные ========
SoftwareSerial sim800(SIM800_TX, SIM800_RX);
FlashHeader header;
char callerNumber[17];
bool delayActive = false;
unsigned long delayTimer = 0;
char delayedNumber[17];
// Тайминги с сервера (get_hash): задержка группы 1, длительность импульса реле
unsigned long g_relayDelayGroup1Ms = 300000UL;
uint16_t g_relayPulseMs = 1000;
unsigned long lastSync = 0;
/* Пошаговая загрузка списка (раньше 281× HTTP блокировали loop и «вешали» шлюз) */
bool g_numberDownloadActive = false;
uint16_t g_numberDownloadPage = 1;
uint16_t g_numberDownloadTotal = 0;
unsigned long g_lastNumberDownloadMs = 0;
bool g_syncFullListMode = true;
uint8_t g_deltaSubPhase = 0;
char httpBuffer[HTTP_BUFFER_SIZE];
#define URL_BUF_SIZE 148
char g_urlBuf[URL_BUF_SIZE];
char g_ussdScratch[48];
bool gprsReady = false;        // Флаг готовности GPRS
bool lastHashHttpOk = false;

// Счётчик перезагрузок (для диагностики)
uint16_t bootCount = 0;
int minFreeRam = 32767;

/* Лог action=log, текст SMS из очереди команд, тело USSD command_ack — по очереди, не параллельно */
char g_logJsonBuf[LOG_JSON_BUF_SIZE];
char g_logEv[13];
char g_logSt[11];
char g_logDet[16];
char g_simLineBuf[64];
char g_apn[32] = APN;
char g_apnUser[24] = APN_USER;
char g_apnPass[24] = APN_PASS;

// +CLIP приходит в waitForResponse/httpPost при перекрывающихся звонках — без очереди processCall не вызывается
bool g_pendingProcessCall = false;
// SMS, прочитанные во время pump (импульс реле), обрабатываем в loop
int g_pendingSmsIndex = -1;
void ensureApiTokenInHeader() {
  if (!isHexToken32(header.apiToken)) {
    strncpy_P(header.apiToken, PSTR(API_TOKEN_FALLBACK), sizeof(header.apiToken) - 1);
    header.apiToken[sizeof(header.apiToken) - 1] = '\0';
  }
}

