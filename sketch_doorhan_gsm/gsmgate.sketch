// RX SoftwareSerial: меньше — больше SRAM; при сбоях приёма поднять до 48–64
#ifndef _SS_MAX_RX_BUFF
#define _SS_MAX_RX_BUFF 32
#endif
#include <SoftwareSerial.h>
#include <SPI.h>
